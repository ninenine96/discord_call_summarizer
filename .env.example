# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token

# Ollama host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Ollama model for summarization (default: llama3:8b-instruct-q4_K_M)
OLLAMA_MODEL=llama3:8b-instruct-q4_K_M

# Whisper model size for local transcription: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=base

# Whisper device: cpu or cuda
WHISPER_DEVICE=cpu

# Whisper compute type: int8, float16, float32 (int8 is fastest on CPU)
WHISPER_COMPUTE_TYPE=int8

# Channel ID where summaries will be posted (right-click channel -> Copy ID)
SUMMARY_CHANNEL_ID=

# How often to post summaries, in seconds (default: 300 = 5 minutes)
SUMMARY_INTERVAL=300
